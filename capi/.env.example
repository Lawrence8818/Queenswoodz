# Meta Conversions API — CRM lead-stage uploader config
# Copy to `.env` and fill in. NEVER commit the real .env (it's gitignored).

# ── Meta ───────────────────────────────────────────────────────────────────
# Your CRM dataset ID. For Queenswoodz use:
#   523313347359817  = "New KL Property CRM"  (last fired Dec 2024, then silent)
META_DATASET_ID=523313347359817

# System-user access token. Needs `ads_management` to send events, and
# `leads_retrieval` (+ access to the lead-form Page) to pull leads with
# pull-leads.mjs. Generate in Business Settings → System Users, or in
# Events Manager → dataset → Settings → Conversions API. Treat like a password.
META_CAPI_TOKEN=

# Facebook Page id that owns your lead forms (used by pull-leads.mjs).
#   100861858282739 = "Lawrence 找幸福屋"
META_PAGE_ID=100861858282739

# How many days back pull-leads.mjs scans for new leads (dedup keeps re-runs clean).
LEAD_LOOKBACK_DAYS=30

# Graph API version (min v22.0 as of 2025; v23.0 is current).
META_API_VERSION=v23.0

# Name of your CRM as it should appear in Meta CRM reporting.
LEAD_EVENT_SOURCE=Queenswoodz CRM

# Only used with the --test flag. Copy from Events Manager → dataset → Test Events.
META_TEST_EVENT_CODE=

# ── Google Sheet input (only needed when running with --sheet) ───────────────
# Path to the downloaded service-account JSON key.
GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json

# Spreadsheet id — the long token in the sheet URL:
#   https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
# To pool several Facebook pages into one dataset, list their sheet ids
# comma-separated, e.g.  SHEET_ID=abc123,def456,ghi789
SHEET_ID=

# A1 range to read (include the header row). Tab name optional; omit it to read
# the first tab. The Meta-delivered sheet runs to column R (lead_status).
SHEET_RANGE=A:R
