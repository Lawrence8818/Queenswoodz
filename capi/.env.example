# Meta Conversions API — CRM lead-stage uploader config
# Copy to `.env` and fill in. NEVER commit the real .env (it's gitignored).

# Your CRM dataset ID. For Queenswoodz / Lawrence Property use:
#   1072574217502347  = "Lawrence Property CRM"  (currently empty — this is the one to feed)
META_DATASET_ID=1072574217502347

# Dataset / system-user access token with ads_management permission.
# Generate in Events Manager → Settings → "Generate access token", or via a
# Business system user. Treat like a password.
META_CAPI_TOKEN=

# Graph API version (min v22.0 as of 2025; v23.0 is current).
META_API_VERSION=v23.0

# Name of your CRM as it should appear in Meta CRM reporting.
LEAD_EVENT_SOURCE=Queenswoodz CRM

# Only used with the --test flag. Copy from Events Manager → dataset → Test Events.
META_TEST_EVENT_CODE=
